{
  "name": "skill-tidy",
  "version": "0.1.5",
  "description": "Local Agent Skill manager for macOS.",
  "main": "electron-main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "serve": "node server.js",
    "pack": "electron-builder --mac dir",
    "dist": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.brainwung.skilltidy",
    "productName": "Skill Tidy",
    "electronDist": "node_modules/electron/dist",
    "files": [
      "electron-main.js",
      "preload.js",
      "server.js",
      "server-lib/**/*",
      "index.html",
      "styles.css",
      "app.js",
      "fallback-skills.js",
      "icon/**/*",
      "build/icon.icns",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "afterSign": "build/afterSign.js",
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "dir"
      ],
      "category": "public.app-category.developer-tools"
    },
    "dmg": {
      "title": "Skill Tidy"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
